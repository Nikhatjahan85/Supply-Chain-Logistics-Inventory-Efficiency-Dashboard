      <aliases enabled='yes' />
      <column caption='On-Time Delivery' datatype='real' default-format='p0.0%' name='[Calculation_0803475686498304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Delivery Status]=&quot;On-Time&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Order ID])' />
      </column>
      <column caption='Inventory Turnover Ratio KPI' datatype='real' name='[Calculation_0803475687403521]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Units Delivered])&#13;&#10;/&#13;&#10;AVG([Inventory Level])' />
      </column>
      <column caption='Stockout Rate %' datatype='real' default-format='p0.0%' name='[Calculation_0803475688083458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Stockout Status]=&quot;Yes&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Order ID])' />
      </column>
      <column caption='Forecast Accuracy %' datatype='real' name='[Calculation_0803475689070595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1-&#13;&#10;(&#13;&#10;ABS(&#13;&#10;SUM([Actual Demand])&#13;&#10;-&#13;&#10;SUM([Demand Forecast])&#13;&#10;)&#13;&#10;/&#13;&#10;SUM([Demand Forecast])&#13;&#10;)' />
      </column>
